{
  "name": "frontend-vue",
  "private": true,
  "version": "0.0.18",
  "description": "Texture Atlas editor (Vue + Vite + Electron shell)",
  "author": "Texture Atlas contributors",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "bump-patch": "node scripts/bump-patch.mjs",
    "build": "npm run bump-patch && vue-tsc -b && vite build",
    "package:vsix": "node scripts/package-vsix.mjs",
    "package:electron": "electron-builder --publish never",
    "package:exe": "npm run build && npm run package:electron",
    "preview": "vite preview",
    "test": "vue-tsc -b && vite build",
    "electron": "electron ."
  },
  "dependencies": {
    "vue": "^3.5.30",
    "vue-i18n": "^9.14.5"
  },
  "build": {
    "appId": "com.textureatlas.editor",
    "productName": "Texture Atlas Editor",
    "copyright": "Copyright © contributors",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Graphics"
    }
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "electron": "^33.4.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5"
  }
}
