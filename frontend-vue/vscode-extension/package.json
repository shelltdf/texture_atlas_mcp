{
  "name": "texture-atlas-editor",
  "displayName": "TextureAtlas",
  "description": "纹理图集编辑器：内置 Webview 预览、MCP 配套（与 frontend-vue / mcp-server 一致）",
  "version": "0.0.13",
  "publisher": "local",
  "private": true,
  "scripts": {},
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:textureAtlas.webview"
  ],
  "main": "./extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "textureAtlasActivity",
          "title": "TextureAtlas",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "textureAtlasActivity": [
        {
          "type": "webview",
          "id": "textureAtlas.webview",
          "name": "TextureAtlas",
          "contextualTitle": "TextureAtlas"
        }
      ]
    },
    "commands": [
      {
        "command": "textureAtlas.openBuiltIn",
        "title": "TextureAtlas: Open in Editor",
        "icon": "$(grid)"
      },
      {
        "command": "textureAtlas.openPreview",
        "title": "TextureAtlas: Open in Editor",
        "icon": "$(grid)"
      },
      {
        "command": "textureAtlas.startPreview",
        "title": "TextureAtlas: Start Dev Server in Terminal (optional)",
        "icon": "$(play)"
      },
      {
        "command": "textureAtlas.refreshWebview",
        "title": "TextureAtlas: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "textureAtlas.showInActivityBar",
        "title": "TextureAtlas: Show Side Bar"
      },
      {
        "command": "textureAtlas.showMcpInfo",
        "title": "TextureAtlas: Show MCP Paths"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "textureAtlas.openBuiltIn",
          "when": "view == textureAtlas.webview",
          "group": "navigation@1"
        },
        {
          "command": "textureAtlas.startPreview",
          "when": "view == textureAtlas.webview",
          "group": "navigation@2"
        },
        {
          "command": "textureAtlas.refreshWebview",
          "when": "view == textureAtlas.webview",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "TextureAtlas",
      "properties": {
        "textureAtlas.previewPort": {
          "type": "number",
          "default": 4174,
          "minimum": 1024,
          "maximum": 65535,
          "description": "可选：本地开发预览（run_web.py / npm run dev）端口。主界面为扩展内置 dist，不依赖此项；仅在使用终端启动开发服务器时需与脚本一致。默认 4174。"
        }
      }
    }
  }
}
